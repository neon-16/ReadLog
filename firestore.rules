rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidStatus(status) {
      return status in ['want_to_read', 'reading', 'finished'];
    }

    function isValidBookPayload(data) {
      return data.keys().hasOnly([
          'id',
          'title',
          'author',
          'genre',
          'status',
          'totalPages',
          'currentPage',
          'progress',
          'source',
          'createdAt',
          'updatedAt'
        ])
        && data.id is string
        && data.id.size() <= 200
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.author is string
        && data.author.size() > 0
        && data.author.size() <= 120
        && data.genre is string
        && data.genre.size() > 0
        && data.genre.size() <= 40
        && data.source is string
        && data.source in ['manual', 'online']
        && data.status is string
        && isValidStatus(data.status)
        && data.totalPages is int
        && data.totalPages > 0
        && data.totalPages <= 10000
        && data.currentPage is int
        && data.currentPage >= 0
        && data.currentPage <= data.totalPages
        && data.progress is int
        && data.progress >= 0
        && data.progress <= 100;
    }

    function isValidUserProfile(profile) {
      return profile is map
        && profile.keys().hasOnly(['displayName', 'email'])
        && profile.displayName is string
        && profile.displayName.size() > 0
        && profile.displayName.size() <= 80
        && profile.email is string
        && profile.email.size() > 0
        && profile.email.size() <= 254;
    }

    function isValidUserDoc(data) {
      return data.keys().hasOnly(['profile', 'readingGoal', 'defaultBookStatus'])
        && (
          !('profile' in data)
          || isValidUserProfile(data.profile)
        )
        && (
          !('readingGoal' in data)
          || (data.readingGoal is int && data.readingGoal >= 1 && data.readingGoal <= 1000)
        )
        && (
          !('defaultBookStatus' in data)
          || (data.defaultBookStatus is string && isValidStatus(data.defaultBookStatus))
        );
    }

    // App stores profile/settings in users/{uid} root document.
    match /users/{userId} {
      allow get, list: if true;
      allow create, update: if isValidUserDoc(request.resource.data);
      allow delete: if false;
    }

    match /users/{userId}/books/{bookId} {
      // Temporary no-auth mode: keep path narrow + validate schema to reduce abuse.
      allow get, list: if true;
      allow create, update: if isValidBookPayload(request.resource.data);
      allow delete: if true;
    }

    // Temporary no-auth mode for a single profile document used by the app.
    match /users/{userId}/profile/info {
      allow get: if true;
      allow create, update: if request.resource.data.keys().hasOnly(['displayName', 'email'])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 80
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 254;
      allow delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
